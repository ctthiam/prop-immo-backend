generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  email     String    @unique
  phone     String?
  address   String?
  plan      String    @default("trial")
  status    String    @default("active")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users      User[]
  owners     Owner[]
  tenants    Tenant[]
  properties Property[]
  contracts  Contract[]
  rentPayments  RentPayment[]
  workOrders  WorkOrder[]
  providers   Provider[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      Role     @default(SECRETAIRE)
  isActive  Boolean  @default(true)
  agencyId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency    Agency?  @relation(fields: [agencyId], references: [id])
}

model Owner {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String?
  phone      String
  address    String?
  idCardNum  String?
  bankInfo   String?
  agencyId   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agency     Agency   @relation(fields: [agencyId], references: [id])
  properties Property[]
}

model Tenant {
  id            String      @id @default(uuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  address       String?
  idCardNum     String?
  profession    String?
  contractType  ContractType @default(HABITATION)
  agencyId      String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  agency        Agency      @relation(fields: [agencyId], references: [id])
  contracts     Contract[]
}

model Property {
  id          String         @id @default(uuid())
  type        String
  name        String
  address     String
  description String?
  rentBase    Float
  status      PropertyStatus @default(VACANT)
  agencyId    String
  ownerId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agency      Agency         @relation(fields: [agencyId], references: [id])
  owner       Owner          @relation(fields: [ownerId], references: [id])
  contracts   Contract[]
  workOrders  WorkOrder[]
}

model Contract {
  id            String         @id @default(uuid())
  reference     String         @unique
  type          ContractType   @default(HABITATION)
  startDate     DateTime
  endDate       DateTime?
  rentBase      Float
  charges       Float          @default(0)
  tom           Float          @default(0)
  managementFee Float          @default(0)
  tax           Float          @default(0)
  rentTTC       Float
  deposit       Float          @default(0)
  status        ContractStatus @default(ACTIVE)
  agencyId      String
  propertyId    String
  tenantId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  agency        Agency         @relation(fields: [agencyId], references: [id])
  property      Property       @relation(fields: [propertyId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  rentPayments  RentPayment[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SECRETAIRE
  COMPTABLE
  PROPRIETAIRE
  LOCATAIRE
}

enum PropertyStatus {
  VACANT
  OCCUPIED
  ARCHIVED
}

enum ContractType {
  HABITATION
  PROFESSIONNEL
}

enum ContractStatus {
  ACTIVE
  RENEWED
  NOTICE
  TERMINATED
}

model RentPayment {
  id            String        @id @default(uuid())
  reference     String        @unique
  amount        Float
  month         Int
  year          Int
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  status        PaymentStatus @default(PENDING)
  agencyId      String
  contractId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  agency        Agency        @relation(fields: [agencyId], references: [id])
  contract      Contract      @relation(fields: [contractId], references: [id])
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  CANCELLED
}

model Provider {
  id         String      @id @default(uuid())
  name       String
  type       String
  phone      String
  email      String?
  address    String?
  agencyId   String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  agency     Agency      @relation(fields: [agencyId], references: [id])
  workOrders WorkOrder[]
}

model WorkOrder {
  id          String          @id @default(uuid())
  reference   String          @unique
  title       String
  description String
  status      WorkOrderStatus @default(PENDING)
  priority    String          @default("NORMAL")
  cost        Float?
  agencyId    String
  propertyId  String
  providerId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  agency      Agency          @relation(fields: [agencyId], references: [id])
  property    Property        @relation(fields: [propertyId], references: [id])
  provider    Provider?       @relation(fields: [providerId], references: [id])
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}